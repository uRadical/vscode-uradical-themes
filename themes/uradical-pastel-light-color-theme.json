    "gitDecoration.modifiedResourceForeground": "#9C8233",
    "gitDecoration.deletedResourceForeground": "#C76B9E",
    "gitDecoration.untrackedResourceForeground": "#3A8F6E",
    "gitDecoration.ignoredResourceForeground": "#A39FC4",
    "gitDecoration.conflictingResourceForeground": "#9277C4",

    "minimap.findMatchHighlight": "#9C8233",
    "selection.background": "#5B8FCF44",
    "breadcrumb.foreground": "#8088AD",
    "breadcrumb.focusForeground": "#3D4468"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8C8CAD", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#7E6A1E" }
    },
    {
      "scope": ["constant.character.escape", "punctuation.definition.template-expression"],
      "settings": { "foreground": "#C76B9E" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#C76B9E" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#9277C4" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#5B8FCF" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#5B8FCF" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#A78DD2" }
    },
    {
      "scope": ["variable", "variable.other", "meta.definition.variable"],
      "settings": { "foreground": "#3D4468" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#9277C4" }
    },
    {
      "scope": ["variable.language", "variable.language.this"],
      "settings": { "foreground": "#C76B9E", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#C76B9E" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#9C8233", "fontStyle": "italic" }
    },
    {
      "scope": ["support.type.property-name", "meta.object-literal.key", "variable.object.property"],
      "settings": { "foreground": "#5B8FCF" }
    },
    {
      "scope": ["constant.other.color", "support.constant"],
      "settings": { "foreground": "#5B8FCF" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#5B8FCF", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#C76B9E", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#9277C4", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#7E6A1E" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#5B8FCF", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#C76B9E" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#7E87AD" }
    }
  ]
}

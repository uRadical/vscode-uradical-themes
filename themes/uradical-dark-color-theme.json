    "gitDecoration.modifiedResourceForeground": "#E1C631",
    "gitDecoration.deletedResourceForeground": "#F659A8",
    "gitDecoration.untrackedResourceForeground": "#4FCB92",
    "gitDecoration.ignoredResourceForeground": "#4A5488",
